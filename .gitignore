# Public-fork hygiene: keep source, tests, and narrative notes; ignore local
# environments, datasets, generated artifacts, and private scratch space.

# Python caches and local tooling
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.DS_Store

# Local environments and logs
.venv
.venv/
.venv-*/
.logs/
logs/
*.log
*.pid
$tmpdir/
.tmp*/

# Upstream / local scratch
modded-nanogpt/
modded-nanogpt

# Local model artifacts
final_model.pt
final_model.int8.ptz

# Datasets and tokenizer binaries
data/datasets/
data/tokenizers/
data/manifest.json
data/docs_selected.jsonl
data/docs_selected.source_manifest.json

# Public repo exclusions: generated runs, external mirrors, theory dumps,
# and large representation-learning artifacts stay local.
theory/
research/competition_prs/
research/iterations/generated/
research/iterations/archive/
research/iterations/iteration_index.jsonl
research/iterations/run_index.jsonl
research/experiment_ledger.csv
research/project_wide/mac_mini_cluster_access.md
research/representation_learning/calibration/
