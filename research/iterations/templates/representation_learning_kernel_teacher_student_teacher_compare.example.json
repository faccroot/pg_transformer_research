{
  "notes": "Queue-mode teacher comparison for the best current kernel student recipe. Hold the student fixed and compare ecology, winner-only, static-mix, and single-source teachers on equal footing.",
  "sweep_slug": "representation-learning-kernel-teacher-student-teacher-compare",
  "dispatch_mode": "queue",
  "queue_parallelism": 1,
  "queue_retry_attempts": 2,
  "script": "tools/representation_learning/train_kernel_teacher_student.py",
  "wrapper_script": "run_cli_json_config.py",
  "support_files": [
    "tools/representation_learning/schemas.py",
    "tools/representation_learning/train_kernel_teacher_student.py",
    "train_gpt_mlx.py",
    "logic_register_mlx.py",
    "early_exit_aux.py",
    "text_prosody_features.py",
    "structural_branching.py",
    "token_category_weighting.py",
    "token_context_weighting.py",
    "sequential_data_filter.py",
    "replay_signal_runtime.py",
    "snapshot_signal_runtime.py",
    "teacher_signal_runtime.py",
    "curriculum_runtime.py",
    "curriculum.py",
    "apollo_mlx.py",
    "turbo_quant_mlx.py",
    "ternary_quant_mlx.py",
    "data/tokenizers/fineweb_1024_bpe.model"
  ],
  "base_args": {
    "tokenizer-path": "~/transformer_research/parameter-golf/data/tokenizers/fineweb_1024_bpe.model",
    "seed": 17,
    "batch-size": 4,
    "epochs": 8,
    "learning-rate": 0.001,
    "max-seq-len": 256,
    "val-fraction": 0.2,
    "ce-weight": 0.0,
    "distill-weight": 1.0,
    "freeze-backbone": false,
    "model-dim": 128,
    "num-layers": 2,
    "num-layer-templates": 2,
    "num-heads": 8,
    "num-kv-heads": 4,
    "mlp-mult": 2,
    "readout-mode": "mean_last",
    "projection-mode": "direct"
  },
  "runs": [
    {
      "slug": "ecology_teacher",
      "notes": "Current best-of-N ecology teacher.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/ecology_teacher"
      }
    },
    {
      "slug": "winner_only_teacher",
      "notes": "Hard winner-only teacher built from verified winner labels.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_winner_only_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/winner_only_teacher"
      }
    },
    {
      "slug": "static_mix_teacher",
      "notes": "Static teacher-mean mixture without per-example ecology routing.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_static_mix_teacher_mean_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/static_mix_teacher"
      }
    },
    {
      "slug": "qwen_teacher",
      "notes": "Single-source Qwen teacher baseline.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_qwen_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/qwen_teacher"
      }
    },
    {
      "slug": "olmo_teacher",
      "notes": "Single-source OLMo teacher baseline.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_olmo_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/olmo_teacher"
      }
    },
    {
      "slug": "phi_teacher",
      "notes": "Single-source Phi teacher baseline.",
      "args": {
        "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_phi_text_v1.npz",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_teacher_compare_v1/phi_teacher"
      }
    }
  ]
}
