{
  "notes": "Readout sweep around the current best kernel-student recipe. Hold the successful small unfrozen pure-distillation setup fixed and test whether a better sequence readout beats masked-mean pooling.",
  "sweep_slug": "representation-learning-kernel-teacher-student-readout",
  "dispatch_mode": "queue",
  "queue_parallelism": 1,
  "queue_retry_attempts": 2,
  "script": "tools/representation_learning/train_kernel_teacher_student.py",
  "wrapper_script": "run_cli_json_config.py",
  "support_files": [
    "tools/representation_learning/schemas.py",
    "tools/representation_learning/build_kernel_teacher_text_dataset.py",
    "tools/representation_learning/train_kernel_teacher_student.py",
    "train_gpt_mlx.py",
    "logic_register_mlx.py",
    "early_exit_aux.py",
    "text_prosody_features.py",
    "structural_branching.py",
    "token_category_weighting.py",
    "token_context_weighting.py",
    "sequential_data_filter.py",
    "replay_signal_runtime.py",
    "snapshot_signal_runtime.py",
    "teacher_signal_runtime.py",
    "curriculum_runtime.py",
    "curriculum.py",
    "apollo_mlx.py",
    "turbo_quant_mlx.py",
    "ternary_quant_mlx.py",
    "data/tokenizers/fineweb_1024_bpe.model"
  ],
  "base_args": {
    "teacher-dataset": "~/transformer_research/parameter-golf/research/representation_learning/priors/qwen_phi_olmo_kernel_teacher_text_v1.npz",
    "tokenizer-path": "~/transformer_research/parameter-golf/data/tokenizers/fineweb_1024_bpe.model",
    "seed": 17,
    "batch-size": 4,
    "epochs": 8,
    "learning-rate": 0.001,
    "max-seq-len": 256,
    "val-fraction": 0.2,
    "ce-weight": 0.0,
    "distill-weight": 1.0,
    "freeze-backbone": false,
    "model-dim": 128,
    "num-layers": 2,
    "num-layer-templates": 2,
    "num-heads": 8,
    "num-kv-heads": 4,
    "mlp-mult": 2,
    "readout-mode": "mean"
  },
  "runs": [
    {
      "slug": "mean",
      "notes": "Current tuned baseline: masked mean pooling.",
      "args": {
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_readout_v1/mean"
      }
    },
    {
      "slug": "last",
      "notes": "Use the final non-pad token hidden state as the readout.",
      "args": {
        "readout-mode": "last",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_readout_v1/last"
      }
    },
    {
      "slug": "attn",
      "notes": "Use a learned attention pooling head over the sequence.",
      "args": {
        "readout-mode": "attn",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_readout_v1/attn"
      }
    },
    {
      "slug": "mean-last",
      "notes": "Fuse masked-mean and last-token readouts through a learned projection.",
      "args": {
        "readout-mode": "mean_last",
        "output-dir": "~/transformer_research/parameter-golf/research/representation_learning/reports/qwen_phi_olmo_kernel_teacher_student_readout_v1/mean_last"
      }
    }
  ]
}
