{
  "notes": "Set REP_LEARN_PRIORS_PATH to a real exported priors artifact. Queue-mode sweep prep will stage any existing file-valued env paths automatically. REP_LEARN_ADAPTER_MODE controls how canonical directions map into target weights; use svd_carrier for the calibrated runtime adapter baseline.",
  "sweep_slug": "mlx-representation-ablation-1h",
  "dispatch_mode": "queue",
  "queue_parallelism": 2,
  "queue_retry_attempts": 4,
  "script": "train_gpt_mlx.py",
  "wrapper_script": "run_train_gpt_mlx_config.py",
  "support_files": [
    "train_gpt_mlx_representation.py",
    "token_category_weighting.py",
    "token_context_weighting.py",
    "logic_register_mlx.py",
    "turbo_quant_mlx.py",
    "ternary_quant_mlx.py",
    "tools/representation_learning/runtime_mlx.py",
    "tools/representation_learning/schemas.py"
  ],
  "base_env": {
    "DATA_PATH": "./data/datasets/fineweb10B_sp1024",
    "TOKENIZER_PATH": "./data/tokenizers/fineweb_1024_bpe.model",
    "VOCAB_SIZE": "1024",
    "ITERATIONS": "1000000",
    "MAX_WALLCLOCK_SECONDS": "3600",
    "TRAIN_SEQ_LEN": "512",
    "TRAIN_BATCH_TOKENS": "8192",
    "VAL_BATCH_SIZE": "8192",
    "GRAD_ACCUM_STEPS": "8",
    "MLX_MAX_MICROBATCH_TOKENS": "4096",
    "TRAIN_LOG_EVERY": "100",
    "VAL_LOSS_EVERY": "0",
    "QUANT_EVAL_EVERY": "0",
    "WARMUP_STEPS": "0",
    "MLX_COMPILE": "0"
  },
  "runs": [
    {
      "slug": "baseline",
      "notes": "Plain GPT baseline control.",
      "env": {
        "RUN_ID": "rep_ab_baseline"
      }
    },
    {
      "slug": "rep-init-weak",
      "script": "train_gpt_mlx_representation.py",
      "notes": "Representation-learning Q/K init with moderate blend.",
      "env": {
        "RUN_ID": "rep_ab_init_weak",
        "REP_LEARN_PRIORS_PATH": "~/transformer_research/parameter-golf/research/representation_learning/priors/priors_v1.npz",
        "REP_LEARN_QK_INIT": "1",
        "REP_LEARN_INIT_STRENGTH": "0.35",
        "REP_LEARN_ADAPTER_MODE": "svd_carrier"
      }
    },
    {
      "slug": "rep-init-strong",
      "script": "train_gpt_mlx_representation.py",
      "notes": "Representation-learning Q/K init with stronger blend.",
      "env": {
        "RUN_ID": "rep_ab_init_strong",
        "REP_LEARN_PRIORS_PATH": "~/transformer_research/parameter-golf/research/representation_learning/priors/priors_v1.npz",
        "REP_LEARN_QK_INIT": "1",
        "REP_LEARN_INIT_STRENGTH": "0.70",
        "REP_LEARN_ADAPTER_MODE": "svd_carrier"
      }
    }
  ]
}
